function extractEmailFromCompany(profile) {
    // Try to extract email from company profile
    if (profile.email) return profile.email;
    if (profile.website) {
        // Try common patterns: contact@website.com, info@website.com
        const domain = new URL(profile.website).hostname;
        return `contact@${domain}`;
    }
    return 'N/A';
}

function generateMockContact(companyName) {
    // Fallback mock data when API is unavailable
    return {
        name: `${companyName} Contact`,
        role: 'Innovation & Business Development',
        linkedIn: `https://linkedin.com/company/${companyName.toLowerCase().replace(/ /g, '-')}`,
        email: `contact@${companyName.toLowerCase().replace(/ /g, '')}.com`,
        phone: '+33 6 XX XX XX XX'
    };
}
