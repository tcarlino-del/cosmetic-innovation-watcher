/**
 * Enriches company data with LinkedIn information
 * Uses Proxycurl API (recommended) or fallback to mock data
 */

const axios = require('axios');
const Apify = require('apify');

exports.enrichWithLinkedIn = async (companyName, country = 'INTERNATIONAL') => {
    const logger = Apify.getLogger();
    const proxycurlKey = process.env.PROXYCURL_API_KEY;

    // If no API key, return mock data
    if (!proxycurlKey) {
        logger.warn(`No PROXYCURL_API_KEY found. Returning mock data for ${companyName}`);
        return generateMockContact(companyName);
    }

    try {
        // Fetch company info from Proxycurl
        const companyProfile = await fetchLinkedInCompany(companyName, proxycurlKey);
        
        if (!companyProfile) {
            return generateMockContact(companyName);
        }

        // Extract key contacts (Innovation, Marketing, Business Dev)
        const keyContact = findKeyContact(companyProfile);
        
        return {
            name: keyContact.name || 'N/A',
            role: keyContact.role || 'N/A',
            linkedIn: keyContact.linkedIn || 'N/A',
            email: keyContact.email || extractEmailFromCompany(companyProfile),
            phone: keyContact.phone || 'N/A'
        };

    } catch (error) {
        logger.warn(`LinkedIn enrichment failed for ${companyName}: ${error.message}`);
        return generateMockContact(companyName);
    }
};

async function fetchLinkedInCompany(companyName, apiKey) {
    try {
        const response = await axios.post(
            'https://nubela.co/proxycurl/api/v2/linkedin/company/search',
            { company_name: companyName },
            {
                headers: {
                    'Authorization': `Bearer ${apiKey}`,
                    'Content-Type': 'application/json'
                },
                timeout: 10000
            }
        );
        return response.data;
    } catch (error) {
        throw new Error(`Proxycurl API error: ${error.message}`);
    }
}

function findKeyContact(companyProfile) {
    const roles = ['Head of Innovation', 'Chief Innovation Officer', 'VP Marketing', 'Head of Business Development', 'CEO'];
    
    // Mock implementation - In production, parse company profile data
    return {
