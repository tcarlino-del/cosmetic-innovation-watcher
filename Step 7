    try {
        logger.info('Fetching from Beauty Innovation Tracker...');
        const innovationData = await fetchBeautyInnovations();
        results.push(...innovationData);
    } catch (error) {
        logger.warn(`Could not fetch from Beauty Innovation Tracker: ${error.message}`);
    }

    // Database 2: Cosmetic Intelligence News Feed
    try {
        logger.info('Fetching from Cosmetic Intelligence...');
        const cosmeticIntel = await fetchCosmeticIntelligence();
        results.push(...cosmeticIntel);
    } catch (error) {
        logger.warn(`Could not fetch from Cosmetic Intelligence: ${error.message}`);
    }

    // Database 3: Incosmetrics Innovation Pipeline
    try {
        logger.info('Fetching from Incosmetrics...');
        const incosmetrics = await fetchIncosmetrics();
        results.push(...incosmetrics);
    } catch (error) {
        logger.warn(`Could not fetch from Incosmetrics: ${error.message}`);
    }

    return results;
};

